import "@a10n/blueprint-typespec";
import "../../../components/review-agent/main.tsp";
import "../../../components/review-api-service/main.tsp";
import "../../../components/code-index-sdk/main.tsp";
import "./pr-review-config.tsp";

using State;
using Components.ReviewAgent;
using Components.ReviewApiService;
using Components.CodeIndexSdk;

@doc("Enables automated AI-powered analysis of pull request diffs, generating structured {@ReviewComment} entries with {@Severity} classification and posting them to GitHub via {@ReviewApiService}. {@ReviewAgent} fetches the diff, invokes the AI model within the 30-second window guaranteed by assumption A02, assembles a {@ReviewSummary}, and persists results to {@ReviewRelationalStore} before the final verdict is submitted.")
@feature
namespace Products.ReviewBot.Features.PrReview {
  @invariant(#{
    predicate: "A {@PullRequest} submitted for review completes with {@ReviewStatus.completed} and at least one {@ReviewComment} posted.",
    why: "The core value of the feature is that every submitted PR gets a review result; without this guarantee the feature is non-functional.",
  })
  op review_completes(): void;

  @invariant(#{
    predicate: "A duplicate trigger for a {@PullRequest} that already has an active {@Review} returns the existing {@Review.id} without creating a second {@Review} record.",
    why: "Webhook retries are common; idempotency prevents duplicate reviews from being posted to GitHub.",
  })
  op trigger_idempotent(): void;

  @invariant(#{
    predicate: "When max_comments is configured, the number of {@ReviewComment} entries posted does not exceed that limit, and the retained comments are the highest-severity ones.",
    why: "Operators set the cap to control noise; violating the cap or choosing wrong comments undermines the feature contract.",
  })
  op cap_enforced(): void;

  @invariant(#{
    predicate: "When severity_threshold is configured, no {@ReviewComment} with {@Severity} strictly below the threshold is posted to GitHub.",
    why: "The threshold is the primary lever for reducing low-value noise; any leak below threshold breaks the operator's expectation.",
  })
  op threshold_filters(): void;

  @invariant(#{
    predicate: "Every {@ReviewComment.body} states a concrete problem and provides actionable guidance.",
    why: "Vague comments have no value to PR authors; actionability is the quality bar for the AI output.",
  })
  op body_actionable(): void;

  @invariant(#{
    predicate: "{@ReviewComment.severity} matches the actual impact of the described issue within one severity tier.",
    why: "Miscalibrated severity misleads reviewers about urgency and erodes trust in the automated review.",
  })
  op severity_calibrated(): void;

  @invariant(#{
    predicate: "Every {@ReviewComment} references a valid {@ReviewComment.file} that exists in the {@PullRequest} diff, and where possible includes a valid {@ReviewComment.line}.",
    why: "Comments without a precise file and line anchor cannot be applied by the PR author and waste review bandwidth.",
  })
  op location_specific(): void;

  @invariant(#{
    predicate: "For each file changed in the {@PullRequest} diff, at least one {@ReviewComment} is produced or an explicit no-issue note is emitted for that file.",
    why: "Gaps in file coverage mean real defects go unreported; full-diff coverage is the completeness baseline.",
  })
  op files_analyzed(): void;

  @invariant(#{
    predicate: "{@ReviewSummary.total_comments} equals the actual count of {@ReviewComment} entries in the result.",
    why: "An inconsistent summary misleads tooling and operators that rely on the count without enumerating the comments.",
  })
  op count_consistent(): void;
}
