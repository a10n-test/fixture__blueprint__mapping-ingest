import "@a10n/blueprint-typespec";
import "../../../components/review-api-service/main.tsp";
import "../../../components/review-ui/main.tsp";
import "../../../components/review-agent/main.tsp";

using State;
using Components.ReviewApiService;
using Components.ReviewUi;
using Components.ReviewAgent;

@doc("Enables human operators to review AI-generated {@ReviewComment} entries before they are posted to GitHub. Operators interact with {@ReviewUi} to approve, edit, or reject individual comments; their decisions are relayed through {@ReviewApiService} back to {@ReviewAgent}, which incorporates accepted comments into the final {@ReviewSummary} and discards rejected ones. This interrupt loop ensures operator oversight over the AI verdict before it reaches the PR author.")
@feature
namespace Products.ReviewBot.Features.ReviewApproval {
  @invariant(#{
    predicate: "When an operator approves a pending review interrupt, all {@ReviewComment} entries and the {@ReviewVerdict} are posted to GitHub and {@Review.status} transitions to {@ReviewStatus.completed}.",
    why: "Approval is the happy path; any failure to post or status mismatch means the operator's decision was lost.",
  })
  op approval_posts_review(): void;

  @invariant(#{
    predicate: "When a pending review interrupt timeout elapses without an operator response, the review is aborted and {@Review.status} transitions to {@ReviewStatus.failed}.",
    why: "Unbounded interrupt waits block the agent session indefinitely; a timeout abort keeps the system from hanging.",
  })
  op timeout_aborts(): void;
}
