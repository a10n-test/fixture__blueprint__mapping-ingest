import "@a10n/blueprint-typespec";
import "../../../components/review-agent/tools/post-review.tsp";

using State;
using Components.ReviewAgent;

namespace Products.ReviewBot.Features.PrReview;


@doc("Tunable parameters for the PR review feature. Controls comment volume, analysis scope, timeouts, approval gating, and severity filtering. All values are enforced at feature runtime; changing them does not require redeployment of {@ReviewAgent}.")
@featureConfig
model PrReviewConfig {
  @doc("Maximum number of {@ReviewComment} entries that {@ReviewAgent} may produce for a single {@PullRequest}. Comments are generated in file-diff order; once this limit is reached, remaining files may not receive inline comments even if issues are present. Lower values reduce noise but increase the risk of missed findings — see E001_04 in eval 001_review-quality for the impact on file coverage score.")
  @minValue(1)
  @maxValue(100)
  maxComments: int32 = 20;

  @doc("Maximum number of changed files that {@ReviewAgent} will read and analyze from the {@PullRequest} diff. Files are processed in the order returned by the GitHub diff API; files beyond this cap are skipped entirely. Increase if large PRs are common; decrease to bound LLM token usage and latency.")
  @minValue(1)
  @maxValue(200)
  maxFilesAnalyzed: int32 = 50;

  @doc("Maximum wall-clock seconds that {@ReviewAgent} may spend on review generation, from first file fetch to {@ReviewSummary} assembly. If the agent does not complete within this budget, the {@Review.status} transitions to {@ReviewStatus.failed} and no comments are posted. Must be kept below the 30-second OpenAI response guarantee stated in assumption A02 multiplied by the expected number of model calls.")
  @minValue(30)
  @maxValue(600)
  reviewTimeoutSeconds: int32 = 120;

  @doc("Maximum hours the system waits for a human decision on a {@Components.ReviewAgent.Tools.post_review_interrupt} before auto-aborting the review. When the timeout expires, {@Components.ReviewAgent.Tools.post_review_interrupt} is cancelled and the {@Review.status} transitions to {@ReviewStatus.failed} with reason 'approval timeout'. Only relevant when {@PrReviewConfig.requireApproval} is true. Set to the longest SLA your team can commit to for reviewing AI output.")
  @minValue(1)
  @maxValue(168)
  approvalTimeoutHours: int32 = 48;

  @doc("Severity floor used to filter {@ReviewComment} entries after generation and before they are posted to GitHub. Any comment whose {@ReviewComment.severity} is strictly below this threshold is discarded. See {@SeverityThreshold} enum for per-value filtering behavior. Note: evals should run against the full pre-filtered list from {@ReviewAgent} to measure true agent quality independently of this policy setting.")
  severityThreshold: SeverityThreshold = SeverityThreshold.minor;

  @doc("When true, {@ReviewAgent} raises a {@Components.ReviewAgent.Tools.post_review_interrupt} after generating the review payload and before posting any comments to GitHub. The reviewing {@Actor} must approve, edit, or reject the payload. When false, the agent posts the review immediately without human gating. Set to false only in fully automated pipelines where operator oversight is not required.")
  requireApproval: boolean = true;

  @doc("When true, {@ReviewAgent} posts each {@ReviewComment} as a GitHub inline comment anchored to the specific {@ReviewComment.file} and {@ReviewComment.line}. When false, all findings are consolidated into a single PR-level review body and no inline comments are created. Use false for repositories where inline comment noise is undesirable or where line-level anchoring is unreliable (e.g. very large diffs).")
  postInlineComments: boolean = true;
}
