import "@a10n/blueprint-typespec";
import "../../components/review-agent/main.tsp";
import "../../components/review-api-service/main.tsp";
import "../../components/code-index-sdk/main.tsp";
import "../../components/review-relational-store/main.tsp";
import "../../components/review-ui/main.tsp";
import "./features/pr-review.tsp";
import "../../components/review-agent/evals/pr-review/001_review-quality.tsp";
import "../../components/review-agent/datasets/pr-review/001_pr_gate.tsp";
import "../../components/review-agent/evals/pr-review/002_pr_gate_suite.tsp";
import "../../components/review-dotdir-file-store/main.tsp";
import "./features/review-approval.tsp";

using State;
using Components.ReviewAgent;
using Components.ReviewApiService;
using Components.CodeIndexSdk;
using Components.ReviewRelationalStore;
using global.Components.ReviewUi;

@doc("Automated code review platform that analyses pull request diffs using AI, generates structured {@ReviewComment} entries with {@Severity} classification, posts them to GitHub, and integrates with the human approval workflow so operators can inspect or override AI output before it reaches the PR author.")
@product
@assumption(#{ id: "A01", assumption: "GitHub REST API is available and the authenticated token carries pull_requests: write scope", source: "github" })
@assumption(#{ id: "A02", assumption: "OpenAI API responds within 30 seconds for review generation requests issued by {@ReviewAgent}", source: "openai" })
@assumption(#{ id: "A03", assumption: "The target repository is indexable — either public or the token used by {@CodeIndexSdk} has read access", source: "github" })
@assumption(#{ id: "A04", assumption: "The PR branch HEAD ref is stable during review; no force-push occurs between the time {@ReviewAgent} reads the diff and the time {@ReviewApiService} posts comments", source: "github" })
namespace Products.ReviewBot {}
