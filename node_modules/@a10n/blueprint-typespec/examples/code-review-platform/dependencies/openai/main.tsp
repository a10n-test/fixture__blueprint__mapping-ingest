import "@a10n/blueprint-typespec";
import "../../components/open-ai-service/main.tsp";
import "../../components/review-agent/main.tsp";
import "../../components/review-api-service/main.tsp";
import "../../components/code-index-sdk/main.tsp";
import "../../components/review-relational-store/main.tsp";

using State;
using Components.ReviewAgent;
using Components.ReviewApiService;
using Components.CodeIndexSdk;
using Components.ReviewRelationalStore;

@doc("OpenAI API providing LLM completions for code review generation and vector embeddings for semantic code search in the ReviewBot platform")
@assumption(#{ id: "A01", assumption: "Model API is stable for gpt-4o and text-embedding-3-small; {@ReviewAgent} and {@CodeIndexSdk} pin to these model identifiers and rely on backward-compatible API responses", source: "https://platform.openai.com/docs/models" })
@assumption(#{ id: "A02", assumption: "Embedding vector dimensions are stable for a given model version — {@CodeIndexSdk} relies on text-embedding-3-small producing 1 536-dimensional vectors consistently across all indexing and query calls without silent dimension changes", source: "https://platform.openai.com/docs/guides/embeddings" })
@dependency(#{
  title: "OpenAI",
  type: DependencyType.Standard,
  status: DependencyStatus.Active,
  sources: #[
    #{
      url: "https://platform.openai.com/docs/api-reference",
      description: "API reference for completions and embeddings endpoints — consult when integrating model calls inside {@ReviewAgent} or {@CodeIndexSdk}",
    },
    #{
      url: "https://platform.openai.com/docs/guides/embeddings",
      description: "Embedding model selection and usage guide — consult when choosing models or understanding dimension guarantees for {@CodeIndexSdk} indexing",
    },
  ],
  why: #[
    "LLM completions API is the core reasoning engine for {@ReviewAgent} — it generates per-file review comments and top-level approval decisions that are ultimately posted by {@ReviewApiService}",
    "Embeddings API enables {@CodeIndexSdk} to convert code chunks into dense vectors for semantic similarity search, so {@ReviewAgent} can retrieve the most relevant context before generating a review",
  ],
  how: #[
    "Completions API (gpt-4o): {@ReviewAgent} sends the PR diff and retrieved code context as a structured prompt and receives a JSON-formatted review with line-level comments and an approval decision stored in {@StoredReview}",
    "Embeddings API (text-embedding-3-small): {@CodeIndexSdk} calls POST /v1/embeddings at index time for each code chunk and at query time for each search request; resulting vectors are compared by cosine similarity inside the index",
  ],
  gotchas: #[
    "Token limits per request: gpt-4o has a 128 k-token context window but large PR diffs can exceed this — {@ReviewAgent} must truncate or summarise the diff before the completion call, or split it into per-file calls",
    "Embedding dimensions are fixed per model: text-embedding-3-small produces 1 536-dimensional vectors; switching to a different model invalidates the entire {@CodeIndexSdk} index because stored vectors become incommensurable with newly generated ones",
    "Rate limits differ between endpoints: completions and embeddings have independent token-per-minute and request-per-minute buckets — {@ReviewAgent} and {@CodeIndexSdk} must handle 429 responses independently rather than sharing a single backoff strategy",
    "Cost scales with context size: each completion call to gpt-4o is billed by input+output tokens; large PR contexts sent by {@ReviewAgent} can produce significant per-review costs — prefer retrieving only the top-k relevant chunks from {@CodeIndexSdk} rather than including the full repository",
  ],
})
namespace Dependencies.Openai {}
