import "@a10n/blueprint-typespec";

using State;

namespace Dependencies.Github;

@doc("Request body for posting a review to a pull request via POST /repos/{owner}/{repo}/pulls/{pull_number}/reviews")
model GithubPostReviewRequest {
  @doc("Top-level review body text summarising the verdict")
  body: string;

  @doc("Review decision: APPROVE, REQUEST_CHANGES, or COMMENT")
  event: "APPROVE" | "REQUEST_CHANGES" | "COMMENT";

  @doc("Line-level comments to post alongside the review")
  comments: GithubReviewComment[];
}

@doc("A single inline comment attached to a specific file and line in the pull request diff")
model GithubReviewComment {
  @doc("Repository-relative file path, e.g. src/main.go")
  path: string;

  @doc("Line number in the diff to attach the comment to")
  line: int32;

  @doc("Comment body text")
  body: string;
}
