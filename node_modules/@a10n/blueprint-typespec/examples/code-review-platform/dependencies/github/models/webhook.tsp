import "@a10n/blueprint-typespec";

using State;

namespace Dependencies.Github;

@doc("Inbound webhook delivery from GitHub. {@ReviewApiService} receives this at POST /webhook/github and verifies the X-Hub-Signature-256 header before parsing.")
model GithubWebhookDelivery {
  @doc("Opaque delivery ID from X-GitHub-Delivery header; used by {@ReviewApiService} for idempotency")
  delivery_id: string;

  @doc("Event type from X-GitHub-Event header, e.g. pull_request")
  event: string;

  @doc("HMAC-SHA256 signature from X-Hub-Signature-256 header; {@ReviewApiService} verifies this before processing")
  signature: string;

  @doc("Raw JSON body; {@ReviewApiService} parses this into {@GithubPullRequestEvent} after signature verification")
  body: unknown;
}

@doc("Parsed pull_request webhook payload — only the fields {@ReviewApiService} extracts at the boundary")
model GithubPullRequestEvent {
  @doc("Action that triggered the event; {@ReviewApiService} processes opened, synchronize, and reopened only")
  action: "opened" | "synchronize" | "reopened" | "closed";

  @doc("PR number within the repository")
  number: int32;

  @doc("HTML URL of the pull request; becomes {@Review.pr_url}")
  html_url: string;

  @doc("Head commit SHA at the time of the event; passed to {@ReviewAgent} as part of {@ReviewInput}")
  head_sha: string;
}
