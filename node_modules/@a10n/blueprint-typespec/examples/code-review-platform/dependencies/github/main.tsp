import "@a10n/blueprint-typespec";
import "./models/main.tsp";
import "../../components/github-service/main.tsp";
import "../../components/review-agent/main.tsp";
import "../../components/review-api-service/main.tsp";

using State;
using Components.ReviewAgent;
using Components.ReviewApiService;

@doc("GitHub integration providing PR webhooks and review-posting capability for the ReviewBot platform")
@assumption(#{ id: "A01", assumption: "REST API is stable and enforces a 5 000 req/hour rate limit per authenticated token for standard endpoints, which {@ReviewApiService} relies on for capacity planning", source: "https://docs.github.com/en/rest/overview/rate-limits-for-the-rest-api" })
@assumption(#{ id: "A02", assumption: "Webhooks are delivered at-least-once and every {@GithubWebhookDelivery} includes {@GithubWebhookDelivery.signature} that {@ReviewApiService} can verify for authenticity before processing", source: "https://docs.github.com/en/webhooks/using-webhooks/validating-webhook-deliveries" })
@assumption(#{ id: "A03", assumption: "PR review API supports {@GithubReviewComment} entries referencing file path and line number, enabling {@ReviewAgent} to post per-line feedback alongside top-level {@GithubPostReviewRequest} decisions", source: "https://docs.github.com/en/rest/pulls/reviews" })
@dependency(#{
  title: "GitHub",
  type: DependencyType.Service,
  status: DependencyStatus.Active,
  sources: #[
    #{
      url: "https://docs.github.com/en/rest",
      description: "REST API reference for PR operations and review posting — consult when integrating pull request lifecycle endpoints",
    },
    #{
      url: "https://docs.github.com/en/webhooks",
      description: "Webhook event payloads and delivery semantics — consult when handling push and pull_request events in the pipeline",
    },
  ],
  why: #[
    "Standard platform for all pull request activity — webhook events originate here, making GitHub the authoritative source of PR lifecycle signals for {@ReviewAgent}",
    "Webhook-driven pipeline: {@ReviewAgent} receives pull_request events (opened, synchronize, reopened) directly from GitHub without polling, keeping end-to-end review latency minimal",
    "PR review API is the only official channel for posting inline code comments and approval decisions that are visible in the GitHub UI to pull request authors, which {@ReviewApiService} uses to surface {@ReviewAgent} output",
  ],
  how: #[
    "Webhook endpoint in {@ReviewApiService} receives {@GithubWebhookDelivery} and parses it into {@GithubPullRequestEvent} after HMAC verification; the extracted fields feed into {@ReviewInput} for {@ReviewAgent}",
    "REST API posts {@GithubPostReviewRequest} with {@GithubReviewComment} entries referencing file path and line number; {@Review.pr_url} is used as the primary key for idempotency checks before each POST",
    "{@Review.pr_url} serves as the canonical identifier linking an inbound {@GithubWebhookDelivery} to its persisted {@Review} record throughout the pipeline",
  ],
  gotchas: #[
    "Webhook deduplication is the caller's responsibility — GitHub delivers each {@GithubWebhookDelivery} at-least-once; {@ReviewApiService} must check {@GithubWebhookDelivery.delivery_id} before enqueuing to avoid duplicate review submissions",
    "Rate limiting: 5 000 requests/hour per authenticated token for standard REST endpoints; write operations (posting {@GithubPostReviewRequest} via {@ReviewApiService}) are additionally subject to secondary rate limits — treat any 429 as a signal to back off using the Retry-After header",
    "Review state is append-only for approval transitions: once {@ReviewStatus.completed} is reached via an APPROVED {@GithubPostReviewRequest}, switching back to REQUEST_CHANGES requires a brand-new {@GithubPostReviewRequest} — the existing approval cannot be mutated in-place",
    "Webhook secret validation is mandatory: GitHub signs every {@GithubWebhookDelivery} with HMAC-SHA256 in {@GithubWebhookDelivery.signature}; {@ReviewApiService} must verify this before processing to prevent spoofed webhook injection",
  ],
})
namespace Dependencies.Github {}
