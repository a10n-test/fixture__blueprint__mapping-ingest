import "@a10n/blueprint-typespec";
import "../../dependencies/github/main.tsp";
import "../github-service/main.tsp";
import "../review-agent/main.tsp";
import "../review-relational-store/main.tsp";
import "./models/main.tsp";
import "./mcp/main.tsp";
import "./http/main.tsp";
import "./events/main.tsp";

using State;
using Dependencies.Github;
using Components.ReviewAgent;
using Components.ReviewRelationalStore;

@doc("HTTP and MCP gateway for the code review automation system. Receives GitHub pull_request webhooks, orchestrates the ReviewAgent execution, streams live progress to clients via SSE, and posts the completed verdict back to GitHub.")
@component(#{
  type: ComponentType.Service,
  source: "https://github.com/example-org/review-bot",
})
@dependsOn([Components.GithubService, Components.ReviewAgent, Components.ReviewRelationalStore])
@testing(Components.GithubService, #{
  approach: TestingApproach.Mock,
  reasoning: "Tests must not post real review comments to live pull requests and must not rely on live webhook delivery. A mock GitHub client returns deterministic pull request fixtures and records post_review calls for assertion. HMAC signature verification is tested with known secrets.",
})
@testing(Components.ReviewAgent, #{
  approach: TestingApproach.Mock,
  reasoning: "ReviewAgent sessions are non-deterministic and expensive. A mock agent returns scripted ReviewResult payloads on demand, enabling deterministic state transition tests and SSE stream emission tests without running the full LLM pipeline.",
})
@testing(Components.ReviewRelationalStore, #{
  approach: TestingApproach.Real,
  reasoning: "Use a real ReviewRelationalStore backed by an in-memory SQLite instance. Review status transitions, idempotency checks, and SSE snapshot accuracy all depend on real query semantics that a mock cannot faithfully reproduce.",
})
namespace Components.ReviewApiService {}
