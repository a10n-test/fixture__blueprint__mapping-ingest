import "@a10n/blueprint-typespec";
import "@typespec/sse";
import "@typespec/events";
import "../models/main.tsp";

using State;
using TypeSpec.SSE;
using TypeSpec.Events;

namespace Components.ReviewApiService;

@doc("Lifecycle events for the ReviewApiService process itself.")
@events
union ServiceLifecycleEvent {
  @doc("Emitted by {@Actor} when the service process starts — triggers in-flight review recovery.")
  started: void;
}

@doc("SSE event union for a per-review stream. {@StreamEventType.STATE_SNAPSHOT} carries the full {@ReviewState} on initial connect and on terminal transitions; {@StreamEventType.STATE_DELTA} carries an incremental {@JsonPatch} array on every intermediate status change.")
@events
union ReviewStreamEvents {
  @doc("Full {@ReviewState} snapshot — emitted immediately on connect and once more when the review reaches a terminal {@ReviewStatus}")
  snapshot: ReviewState;

  @doc("Incremental RFC-6902 {@JsonPatch} array — emitted on every status transition between snapshot events")
  delta: JsonPatch;

  @doc("Terminal event emitted when the review reaches {@ReviewStatus.completed} or {@ReviewStatus.failed}; clients should close the connection")
  @terminalEvent
  done: void;
}
