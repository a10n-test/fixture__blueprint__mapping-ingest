import "@a10n/blueprint-typespec";
import "./review.tsp";

using State;

namespace Components.ReviewApiService;

@doc("Discriminates the type of SSE event emitted on a review stream")
enum StreamEventType {
  @doc("Full state snapshot — emitted immediately on connect and once more when the review reaches a terminal status")
  STATE_SNAPSHOT: "STATE_SNAPSHOT",

  @doc("Incremental RFC-6902 JSON Patch — emitted on every status transition between snapshot events")
  STATE_DELTA: "STATE_DELTA",
}

@doc("Generic SSE wrapper emitted on a review stream. {@StreamEventType.STATE_SNAPSHOT} on initial connect or terminal state; {@StreamEventType.STATE_DELTA} (JSON Patch) on change.")
model StreamEvent<T> {
  @doc("Discriminates snapshot vs incremental update: {@StreamEventType.STATE_SNAPSHOT} carries the full T, {@StreamEventType.STATE_DELTA} carries a {@JsonPatch} array")
  event: StreamEventType;

  @doc("Full state snapshot or RFC-6902 JSON Patch array depending on the event field")
  data: T | JsonPatch;
}

@doc("RFC-6902 JSON Patch array used in STATE_DELTA SSE events")
model JsonPatch is Array<{
  @doc("Patch operation type")
  `op`: "add" | "remove" | "replace";

  @doc("JSON Pointer (RFC 6901) targeting the field to mutate")
  path: string;

  @doc("New value for add/replace operations; omitted for remove")
  value?: unknown;
}>;

@doc("Point-in-time state of a single review as broadcast over the SSE stream at /reviews/{review_id}/stream")
model ReviewState {
  @doc("Review identifier matching the stream path parameter")
  id: string;

  @doc("Current lifecycle status; transitions follow the {@ReviewStatus} state machine")
  status: ReviewStatus;

  @doc("Optional verdict text available once status reaches {@ReviewStatus.completed}")
  verdict?: string;

  @doc("ISO-8601 timestamp of the most recent status transition")
  updated_at: utcDateTime;
}
