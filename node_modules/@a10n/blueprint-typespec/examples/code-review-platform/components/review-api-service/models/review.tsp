import "@a10n/blueprint-typespec";
import "../../review-agent/models/main.tsp";

using State;
using Components.ReviewAgent;

namespace Components.ReviewApiService;

@doc("Lifecycle status of a code review")
enum ReviewStatus {
  @doc("Review request received; queued for processing but not yet dispatched to the review agent")
  pending: "pending",

  @doc("Review agent is actively analyzing the pull request diff")
  running: "running",

  @doc("Review agent completed successfully and verdict has been posted to GitHub")
  completed: "completed",

  @doc("Review agent encountered an unrecoverable error; see verdict field for details")
  failed: "failed",

  @doc("Review was explicitly cancelled by an operator before the agent completed")
  cancelled: "cancelled",
}

@doc("A code review record tracking the full lifecycle from webhook receipt to verdict posting")
model Review {
  @doc("Unique opaque identifier for this review, generated at creation time")
  id: string;

  @doc("Full GitHub pull request URL, e.g. https://github.com/org/repo/pull/42")
  pr_url: string;

  @doc("Current processing status of the review")
  status: ReviewStatus;

  @doc("ISO-8601 timestamp when the review was created")
  created_at: utcDateTime;

  @doc("Human-readable verdict summary posted back to the pull request; populated only when {@ReviewStatus.completed}")
  verdict?: string;
}

@doc("Optional configuration knobs passed when triggering a review programmatically via MCP")
model ReviewOptions {
  @doc("Number of surrounding context lines to fetch when analyzing a finding; defaults to 4")
  context_depth?: int32;

  @doc("Comma-separated list of glob patterns to exclude from analysis, e.g. '**/*.generated.ts,vendor/**'")
  exclude_patterns?: string;

  @doc("When true, the agent posts review comments to GitHub in addition to returning the verdict; defaults to true")
  post_to_github?: boolean;
}

@doc("Runtime configuration for the review service — controls comment volume, severity filtering, and notification preferences")
model ReviewConfig {
  @doc("Severity floor below which {@ReviewComment} entries are dropped before posting to GitHub; see {@SeverityThreshold} for values")
  severity_threshold: string = "minor";

  @doc("Maximum number of {@ReviewComment} entries posted per review; comments are ranked by severity and truncated to this limit")
  @minValue(1)
  @maxValue(100)
  max_comments: int32 = 20;

  @doc("Notification channel identifier to alert when a review completes, fails, or requires human approval")
  notification_channel?: string;
}

@doc("Webhook event delivered by the review API when a new review is triggered or its status changes")
model ReviewWebhookEvent {
  @doc("Unique identifier of the review associated with this webhook delivery")
  review_id: string;

  @doc("Current lifecycle status of the review at the time of this event")
  status: ReviewStatus;

  @doc("ISO-8601 timestamp when this event was emitted")
  emitted_at: utcDateTime;
}
