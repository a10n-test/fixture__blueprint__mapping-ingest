import "@a10n/blueprint-typespec";
import "../../../dependencies/github/main.tsp";
import "../../review-agent/main.tsp";
import "../models/main.tsp";
import "../../review-relational-store/main.tsp";

using State;
using Dependencies.Github;
using Components.ReviewAgent;
using Components.ReviewRelationalStore;

namespace Components.ReviewApiService.Flows.GithubWebhook;

@flow
@dependsOn([Components.GithubService, Components.ReviewAgent])
@writes([StoredReview, StoredComment])
@reads([StoredReview])
@doc("""
GitHub delivers a {@GithubWebhookDelivery} to ReviewApiService, which verifies {@GithubWebhookDelivery.signature}, deduplicates by {@GithubWebhookDelivery.delivery_id}, creates a {@Review} in {@ReviewStatus.pending}, dispatches {@ReviewInput} to {@ReviewAgent}, streams {@ReviewComment} deltas back via {@StreamEvent}, and posts {@GithubPostReviewRequest} with the completed {@ReviewResult} verdict back to GitHub.

```mermaid
sequenceDiagram
    participant GH as GitHub
    participant RA as ReviewApiService
    participant AG as ReviewAgent
    participant DB as ReviewRelationalStore

    GH->>RA: {@GithubWebhookDelivery}
    Note over RA: Verify {@GithubWebhookDelivery.signature}
    RA->>DB: INSERT {@Review} (status={@ReviewStatus.pending}, pr_url=...)
    RA-->>GH: 200 OK {review_id}

    RA->>AG: dispatch({@ReviewInput})
    RA->>DB: UPDATE {@Review} status={@ReviewStatus.running}
    RA-->>RA: SSE stream opened at /reviews/{review_id}/stream

    AG-->>RA: SSE {@ReviewComment} deltas (streaming)
    RA-->>RA: {@StreamEvent} ({@StreamEventType.STATE_DELTA}) to connected SSE clients

    AG-->>RA: {@ReviewResult} (session complete)
    RA->>GH: {@GithubPostReviewRequest}
    RA->>DB: UPDATE {@Review} status={@ReviewStatus.completed}, verdict=summary
    RA-->>RA: {@StreamEvent} ({@StreamEventType.STATE_SNAPSHOT}, terminal), stream closes
```

### Idempotency

GitHub may redeliver the same {@GithubWebhookDelivery} (same {@GithubWebhookDelivery.delivery_id}). ReviewApiService deduplicates on {@GithubWebhookDelivery.delivery_id} before inserting a new {@Review} row. Duplicate deliveries return the existing {@Review.id} with 200 status.
""")
op github_webhook_flow(): void;
