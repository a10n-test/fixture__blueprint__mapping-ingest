import "@a10n/blueprint-typespec";
import "../models/main.tsp";
import "../../review-agent/main.tsp";
import "../../review-relational-store/main.tsp";

using State;
using Components.ReviewAgent;
using Components.ReviewRelationalStore;

namespace Components.ReviewApiService.Flows.ReviewStatus;

@flow
@dependsOn([Components.ReviewAgent])
@reads([StoredReview])
@writes([StoredReview])
@doc("""
Lifecycle of {@Review.status} through the {@ReviewStatus} values. Cancellation via \\{@cancel_review} is only valid from {@ReviewStatus.pending} and {@ReviewStatus.running}; all other states are terminal.

```mermaid
stateDiagram-v2
    [*] --> pending : {@ReviewWebhookEvent} received / \\{@trigger_review}
    pending --> running : {@ReviewInput} dispatched to {@ReviewAgent}
    running --> completed : {@ReviewAgent} returned {@ReviewResult}
    running --> failed : {@ReviewAgent} error or timeout
    pending --> failed : dispatch rejected
    pending --> cancelled : \\{@cancel_review}
    running --> cancelled : \\{@cancel_review}
    completed --> [*]
    failed --> [*]
    cancelled --> [*]
```

Terminal states: {@ReviewStatus.completed}, {@ReviewStatus.failed}, {@ReviewStatus.cancelled}.
Non-terminal: {@ReviewStatus.pending}, {@ReviewStatus.running}.
""")
op review_status_flow(): void;
