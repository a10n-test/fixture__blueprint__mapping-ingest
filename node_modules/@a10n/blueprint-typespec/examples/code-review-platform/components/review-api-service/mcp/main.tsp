import "@a10n/blueprint-typespec";
import "typespec-mcp";
import "../models/main.tsp";
import "../../review-relational-store/main.tsp";

using MCP;
using State;
using Components.ReviewRelationalStore;

@mcpServer(#{
  name: "ReviewApiService",
  version: "1.0.0",
  instructions: "Use this MCP server to trigger, inspect, and cancel code reviews for GitHub pull requests. All operations are non-blocking; poll get_review or subscribe to the SSE stream for live progress.",
})
namespace Components.ReviewApiService.Mcp {
@doc("Error returned when a review with the given PR URL is already running")
model TriggerReviewError {
  code: "REVIEW_ALREADY_RUNNING";
  message: string;
}

@doc("Error returned when a review ID does not exist")
model ReviewNotFoundError {
  code: "REVIEW_NOT_FOUND";
  message: string;
}

@doc("Error returned when a review cannot be cancelled due to its current status")
model ReviewNotCancellableError {
  code: "REVIEW_NOT_CANCELLABLE";
  message: string;
}

@doc("Trigger a new code review for the given pull request URL. Returns immediately with a review_id and pending status; stream /reviews/{review_id}/stream for live progress.")
@MCP.tool
@writes([StoredReview])
op trigger_review(
  @doc("Full GitHub pull request URL, e.g. https://github.com/org/repo/pull/42")
  pr_url: string,

  @doc("Optional configuration overrides for this review run")
  options?: ReviewOptions,
): {
  @doc("Opaque review identifier; use with get_review or the SSE stream")
  review_id: string;

  @doc("Initial status is always pending at creation time")
  status: "pending";
} | TriggerReviewError;

@doc("Fetch the current state of a review by ID. Poll this or subscribe to /reviews/{review_id}/stream for live updates.")
@MCP.tool
@reads([StoredReview])
op get_review(
  @doc("Review identifier returned by trigger_review")
  review_id: string,
): Review | ReviewNotFoundError;

@doc("Cancel an in-flight review. Only reviews in pending or running state can be cancelled; completed or failed reviews are terminal.")
@MCP.tool
@writes([StoredReview])
op cancel_review(
  @doc("Review identifier to cancel")
  review_id: string,
): Review | ReviewNotFoundError | ReviewNotCancellableError;
}