import "@a10n/blueprint-typespec";
import "@typespec/http";
import "@typespec/sse";
import "@typespec/events";
import "../models/main.tsp";
import "../events/main.tsp";
import "../../../dependencies/github/main.tsp";
import "../../review-relational-store/main.tsp";
import "../../review-agent/main.tsp";
import "../../code-index-sdk/main.tsp";

using State;
using Http;
using TypeSpec.SSE;
using Dependencies.Github;
using Components.ReviewRelationalStore;
using Components.CodeIndexSdk;

@service(#{ title: "Review API HTTP" })
@server("http://localhost:3000", "Local development server")
namespace Components.ReviewApiService.Http {

@route("/")
@doc("HTTP REST interface for the ReviewApiService service — provides CRUD access to reviews and a GitHub webhook receiver")
interface ReviewApiServiceHTTP {

  @post
  @route("/reviews")
  @doc("Create a new review. Accepts a pr_url and optional configuration; returns the created {@Review} with status {@ReviewStatus.pending}. This is the HTTP equivalent of the MCP \\{@trigger_review} tool.")
  @writes([StoredReview])
  triggerReview(
    @body body: {
      @doc("Full GitHub pull request URL, e.g. https://github.com/org/repo/pull/42")
      pr_url: string;

      @doc("Optional tuning parameters for this review run")
      options?: ReviewOptions;
    },
  ): Review | NotFoundResponse;

  @get
  @route("/reviews/{review_id}")
  @doc("Fetch a single review by ID. Returns the full {@Review} model including current status and verdict if available.")
  @reads([StoredReview])
  @writes([StoredReview])
  getReview(
    @path review_id: string,
  ): Review | NotFoundResponse;

  @get
  @route("/reviews")
  @doc("List reviews with optional status filter and cursor-based pagination.")
  @reads([StoredReview])
  @writes([StoredReview])
  listReviews(
    @doc("Filter by lifecycle status; omit to return all reviews")
    @query status?: ReviewStatus,

    @doc("Maximum number of reviews to return per page; defaults to 20, max 100")
    @query limit?: int32,

    @doc("Opaque pagination cursor returned by the previous page response")
    @query cursor?: string,
  ): {
    @doc("Ordered list of {@Review} records for this page")
    reviews: Review[];

    @doc("Opaque cursor to pass as the cursor query parameter to fetch the next page; absent when there are no more results")
    next_cursor?: string;

    @doc("Total count of reviews matching the filter across all pages")
    total: int32;
  };

  @delete
  @route("/reviews/{review_id}")
  @doc("Cancel an in-flight review. Only reviews in {@ReviewStatus.pending} or {@ReviewStatus.running} state can be cancelled; completed or failed reviews are terminal.")
  @writes([StoredReview])
  cancelReview(
    @path review_id: string,
  ): Review | NotFoundResponse;

  @get
  @route("/config")
  @doc("Fetch the current {@ReviewConfig} for this service instance.")
  @reads([StoredReview])
  getConfig(): ReviewConfig;

  @put
  @route("/config")
  @doc("Update the service-level {@ReviewConfig}. Changes take effect for reviews triggered after this call.")
  @writes([StoredReview])
  updateConfig(
    @body config: ReviewConfig,
  ): ReviewConfig;

  @post
  @route("/reviews/{review_id}/resume")
  @doc("Resume a paused review by submitting the operator decision on a {@Components.ReviewAgent.Tools.post_review_interrupt}.")
  @writes([StoredReview])
  resumeReview(
    @path review_id: string,
    @body body: {
      @doc("Operator decision: approve, reject, or edit")
      decision: string;

      @doc("Edited verdict text; only relevant when decision is 'edit'")
      verdict?: string;
    },
  ): Review | NotFoundResponse;

  @post
  @route("/index")
  @doc("Trigger a repository index job via the {@Components.CodeIndexSdk}. Used by the settings UI to update the code index after configuration changes.")
  @calls([index_repo])
  @writes([StoredReview])
  triggerIndex(
    @body body: { repo_url: string; ref: string; },
  ): { job_id: string; };

  @post
  @route("/webhook/github")
  @doc("GitHub webhook receiver. Accepts pull_request events signed with HMAC-SHA256. On a valid opened or synchronize action the handler validates the signature, deduplicates by X-GitHub-Delivery ID, and enqueues a new review pipeline. Returns 200 immediately; processing is asynchronous.")
  @calls([Components.ReviewAgent.Graph.run])
  @reads([StoredReview])
  @writes([StoredReview, StoredComment])
  @projects(
    Products.ReviewBot.Features.PrReview.review_completes,
    Products.ReviewBot.Features.PrReview.trigger_idempotent
  )
  githubWebhook(
    @doc("Raw GitHub webhook payload; shape depends on X-GitHub-Event header value")
    @body body: GithubWebhookDelivery,
  ): {
    @doc("Acknowledgement message confirming receipt of the webhook")
    message: string;

    @doc("Review ID created or null when the event was deduplicated or ignored")
    review_id?: string;
  };
}

@doc("SSE event stream interface for the ReviewApiService service.")
interface ReviewApiServiceStreams {
  @get
  @route("/reviews/{review_id}/stream")
  @doc("Per-review SSE stream. Emits an immediate snapshot of the current {@ReviewState} on connect, then delta patches on every transition. The stream closes automatically once the review enters {@ReviewStatus.completed} or {@ReviewStatus.failed}.")
  @reads([StoredReview])
  reviewStream(
    @doc("Review identifier whose state changes to stream")
    @path review_id: string,
  ): SSEStream<ReviewStreamEvents>;
}
}
