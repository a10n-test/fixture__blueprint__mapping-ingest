import "@a10n/blueprint-typespec";
import "../tools/analyze-diff.tsp";
import "../tools/fetch-context.tsp";
import "../tools/post-review.tsp";
import "../../review-dotdir-file-store/main.tsp";

using State;
using Components.ReviewDotdirFileStore;

namespace Components.ReviewAgent;

@graph
namespace Graph {
  model State {
    pr_url: string;
  }

  @node(#{ is_entrypoint: true })
  @calls([Tools.fetch_context, Tools.analyze_diff, Tools.post_review, classify_findings])
  @reads([PluginRegistry, HookScript])
  op run(state: Graph.State): Command<{}, End>;

  @node
  op done(state: Graph.State): Command<{}, End>;

  @predict op classify_findings(diff: string): ReviewResult;
}
