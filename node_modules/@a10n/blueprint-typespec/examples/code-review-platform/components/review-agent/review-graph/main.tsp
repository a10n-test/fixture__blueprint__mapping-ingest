import "@a10n/blueprint-typespec";
import "../tools/analyze-diff.tsp";
import "../tools/fetch-context.tsp";
import "../tools/post-review.tsp";

using State;

namespace Components.ReviewAgent {
  @graph
  namespace ReviewGraph {
    model State {
      pr_url: string;
    }

    @node(#{ is_entrypoint: true })
    @calls([Tools.fetch_context, Tools.analyze_diff, Tools.post_review])
    op run(state: ReviewGraph.State): Command<{}, End>;

    @node
    op done(state: ReviewGraph.State): Command<{}, End>;
  }
}
