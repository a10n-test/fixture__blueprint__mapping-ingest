import "@a10n/blueprint-typespec";

using State;

namespace Components.ReviewAgent;

@doc("Severity level of a review finding")
enum Severity {
  @doc("Correctness bug, security vulnerability, or data-loss risk that must be fixed before merge")
  critical: "critical",

  @doc("Significant quality issue or logic error that should be fixed before merge")
  major: "major",

  @doc("Code quality or maintainability issue; recommended but not blocking")
  minor: "minor",

  @doc("Style preference or optional suggestion with no functional impact")
  nitpick: "nitpick",
}

@doc("The overall verdict for the pull request review")
enum ReviewVerdict {
  @doc("No significant issues found; pull request is ready to merge")
  approve: "approve",

  @doc("One or more blocking issues found; author must address before merge")
  request_changes: "request_changes",

  @doc("Non-blocking comments posted; no explicit approval or rejection")
  comment: "comment",
}

@doc("A single review comment attached to a specific file and line")
model ReviewComment {
  @doc("Repository-relative path of the file this comment applies to")
  file: string;

  @doc("Line number in the file where the comment is anchored")
  line: int32;

  @doc("Human-readable review comment body explaining the finding")
  body: string;

  @doc("Severity classification of this finding")
  severity: Severity;

  @doc("Optional concrete code suggestion the author can apply directly")
  suggestion?: string;
}

@doc("Input passed to the review agent at session start")
model ReviewInput {
  @doc("Full URL of the pull request to review, e.g. https://github.com/org/repo/pull/42")
  pr_url: string;

  @doc("Repository-relative paths of files changed in this pull request")
  changed_files: string[];

  @doc("Number of surrounding lines of context to fetch when analyzing a finding; higher values increase accuracy at the cost of token usage")
  context_depth: int32;
}

@doc("Result emitted when the review agent session completes")
model ReviewResult {
  @doc("All review comments generated across the changed files")
  comments: ReviewComment[];

  @doc("Overall verdict for the pull request derived from the collected findings")
  overall_verdict: ReviewVerdict;

  @doc("Human-readable summary of the review rationale and key findings")
  summary: string;
}

@doc("A GitHub pull request being analyzed by the review agent")
model PullRequest {
  @doc("Full URL of the pull request, e.g. https://github.com/org/repo/pull/42")
  url: string;

  @doc("Source branch name being merged")
  head_ref: string;

  @doc("Target branch name that the PR merges into")
  base_ref: string;

  @doc("Title of the pull request")
  title: string;

  @doc("GitHub login of the pull request author")
  author: string;
}

@doc("A human operator or automated system that can interact with the review workflow")
model Actor {
  @doc("Identifier of the actor, e.g. GitHub username or service account name")
  id: string;

  @doc("Human-readable display name")
  name: string;
}

@doc("Aggregated summary of the review output produced by the agent after analyzing all changed files")
model ReviewSummary {
  @doc("Total number of {@ReviewComment} entries produced across all analyzed files")
  total_comments: int32;

  @doc("Number of {@Severity.critical} findings")
  critical_count: int32;

  @doc("Number of {@Severity.major} findings")
  major_count: int32;

  @doc("Overall review verdict derived from the severity distribution")
  verdict: ReviewVerdict;

  @doc("Human-readable narrative summarizing the key findings and rationale for the verdict")
  narrative: string;
}

@doc("Severity floor controlling which {@ReviewComment} entries survive the post-analysis filter. Comments whose {@Severity} is strictly below this threshold are dropped before being posted to GitHub.")
enum SeverityThreshold {
  @doc("No filtering — every {@ReviewComment} is kept regardless of {@Severity}")
  all: "all",

  @doc("Keep {@Severity.minor}, {@Severity.major}, and {@Severity.critical} comments; drop {@Severity.nitpick}")
  minor: "minor",

  @doc("Keep only {@Severity.major} and {@Severity.critical} comments")
  major: "major",

  @doc("Keep only {@Severity.critical} comments")
  critical: "critical",
}
