import "@a10n/blueprint-typespec";
import "../../dependencies/github/main.tsp";
import "../../dependencies/openai/main.tsp";
import "../github-service/main.tsp";
import "../open-ai-service/main.tsp";
import "../review-relational-store/main.tsp";
import "../code-index-sdk/main.tsp";
import "../review-dotdir-file-store/main.tsp";
import "./models/main.tsp";
import "./tools/analyze-diff.tsp";
import "./tools/post-review.tsp";
import "./tools/fetch-context.tsp";
import "./graph/main.tsp";

using State;
using Dependencies.Github;
using Dependencies.Openai;
using Components.ReviewRelationalStore;
using Components.CodeIndexSdk;
using Components.ReviewDotdirFileStore;

@doc("Performs automated code review on pull requests. Reads changed files, analyzes diffs for issues, synthesizes a verdict, and posts structured review comments back to GitHub.")
@component(#{
  type: ComponentType.Agent,
  source: "https://github.com/example-org/review-bot",
})
@dependsOn([Components.GithubService, Components.OpenAIService, Components.ReviewRelationalStore, Components.CodeIndexSdk, Components.ReviewDotdirFileStore])
@testing(Components.GithubService, #{
  approach: TestingApproach.Mock,
  reasoning: "Tests must not post real review comments to live pull requests. A mock GitHub client returns deterministic diff fixtures and records post_review calls for assertion.",
})
@testing(Components.OpenAIService, #{
  approach: TestingApproach.Mock,
  reasoning: "Replace the LLM with a controllable fake that returns deterministic ReviewComment arrays. Eliminates non-determinism from model temperature and makes evals reproducible.",
})
@testing(Components.ReviewRelationalStore, #{
  approach: TestingApproach.Real,
  reasoning: "Use a real ReviewRelationalStore backed by an in-memory SQLite instance to verify that post_review correctly persists StoredComment entries and updates StoredReview status.",
})
@testing(Components.ReviewDotdirFileStore, #{
  approach: TestingApproach.Real,
  reasoning: "The file-store contract is a file layout on disk; test with a real temporary directory to verify hook scripts and plugin registry are read and written at the correct paths.",
})
@testing(Components.CodeIndexSdk, #{
  approach: TestingApproach.Mock,
  reasoning: "Replace the CodeIndexSdk with a fake that returns deterministic code chunks and file content, keeping analyze_diff and fetch_context tests fast and reproducible without a live index.",
})
namespace Components.ReviewAgent {}
