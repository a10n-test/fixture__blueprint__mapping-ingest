import "@a10n/blueprint-typespec";
import "../models/main.tsp";
import "../../../components/code-index-sdk/main.tsp";

using State;
using Components.CodeIndexSdk;

namespace Components.ReviewAgent.Tools;

@doc("Error when file is not part of the pull request diff")
model FileNotFoundError {
  code: "FILE_NOT_FOUND";
  message: string;
}

@doc("Error when diff exceeds maximum line limit")
model DiffTooLargeError {
  code: "DIFF_TOO_LARGE";
  message: string;
}

@doc("Read the diff for a single changed file and return a list of review findings.")
@tool(#{
  sequential: false,
})
@calls([Components.CodeIndexSdk.Operations.get_file, Components.CodeIndexSdk.Operations.list_changed_files])
@projects(Products.ReviewBot.Features.PrReview.threshold_filters)
op analyze_diff(
  @doc("Full URL of the pull request whose diff is being analyzed")
  pr_url: string,

  @doc("Repository-relative path of the file to analyze")
  file_path: string,

  @doc("Maximum number of diff lines to process")
  max_diff_lines: int32,
): {
  @doc("Review findings extracted from the diff for this file")
  findings: ReviewComment[];

  @doc("Total number of diff lines processed")
  lines_processed: int32;
} | FileNotFoundError | DiffTooLargeError;
