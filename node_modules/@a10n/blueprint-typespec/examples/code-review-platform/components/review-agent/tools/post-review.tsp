import "@a10n/blueprint-typespec";
import "../models/main.tsp";
import "../../../components/review-relational-store/main.tsp";

using State;
using Components.ReviewRelationalStore;

namespace Components.ReviewAgent.Tools;

model PostReviewInterruptInput {
  @doc("Review comments to be posted; the operator may edit these before approving")
  comments: ReviewComment[];

  @doc("Proposed overall verdict to submit with the review")
  verdict: ReviewVerdict;

  @doc("Human-readable summary of the review rationale")
  summary: string;
}

model PostReviewDecision {
  @doc("Comments approved or edited by the operator")
  comments: ReviewComment[];

  @doc("Verdict approved or edited by the operator")
  verdict: ReviewVerdict;
}

@doc("The review record persisted to GitHub after a successful {@post_review} call")
model PostedReview {
  @doc("GitHub-assigned identifier for the submitted review")
  review_id: string;

  @doc("Full URL of the review on GitHub")
  html_url: string;

  @doc("Verdict submitted with this review")
  verdict: ReviewVerdict;

  @doc("Total number of comments posted in this review")
  comment_count: int32;

  @doc("ISO-8601 timestamp when the review was submitted")
  submitted_at: string;
}

@doc("Error when pull request is not found or has been deleted")
model PullRequestNotFoundError {
  code: "PR_NOT_FOUND";
  message: string;
}

@doc("Error when authenticated token lacks write permission")
model PermissionDeniedError {
  code: "PERMISSION_DENIED";
  message: string;
}

/** Interrupt op — pauses post_review for operator approval of the proposed review. */
@interrupt
@reads([StoredReview])
@projects(
  Products.ReviewBot.Features.ReviewApproval.approval_posts_review,
  Products.ReviewBot.Features.ReviewApproval.timeout_aborts
)
op post_review_interrupt(input: PostReviewInterruptInput): PostReviewDecision;

@doc("Post the completed review to GitHub. Pauses for operator approval before posting.")
@tool(#{
  sequential: true,
})
@calls([post_review_interrupt])
@writes([StoredComment, StoredReview])
@artifact(PostedReview)
@projects(Products.ReviewBot.Features.PrReview.cap_enforced)
op post_review(
  @doc("Full URL of the pull request to post the review on")
  pr_url: string,

  @doc("Review comments to post as inline annotations on the diff")
  comments: ReviewComment[],

  @doc("Overall verdict to submit with the review")
  verdict: ReviewVerdict,

  @doc("Human-readable summary to include in the review body")
  summary: string,
): PostedReview | PullRequestNotFoundError | PermissionDeniedError;
