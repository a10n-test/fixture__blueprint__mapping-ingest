import "@a10n/blueprint-typespec";
import "../models/main.tsp";
import "../../../components/code-index-sdk/main.tsp";

using State;
using Components.CodeIndexSdk;

namespace Components.ReviewAgent.Tools;

@doc("Error when file does not exist in the repository")
model FileNotFoundInContextError {
  code: "FILE_NOT_FOUND";
  message: string;
}

@doc("Fetch surrounding lines of code around a specific file and line to provide context for a finding. Safe to call in parallel with other \\{@fetch_context} calls.")
@tool(#{
  sequential: false,
})
@calls([Components.CodeIndexSdk.Operations.search])
op fetch_context(
  @doc("Full URL of the pull request; used to resolve the head ref for file access")
  pr_url: string,

  @doc("Repository-relative path of the file to read context from")
  file_path: string,

  @doc("Center line around which context is fetched")
  line: int32,

  @doc("Number of lines to include before and after the center line")
  context_depth: int32,
): {
  @doc("Source lines returned, each entry is one line of source code")
  lines: string[];

  @doc("Line number of the first entry in lines")
  start_line: int32;

  @doc("Line number of the last entry in lines")
  end_line: int32;
} | FileNotFoundInContextError;
