import "@a10n/blueprint-typespec";
import "../../../../components/review-agent/main.tsp";
import "../../../../components/review-agent/evals/pr-review/001_review-quality.tsp";
import "../../../../components/review-agent/datasets/pr-review/001_pr_gate.tsp";

using State;
using Components.ReviewAgent;

namespace Components.ReviewAgent;


@doc("Typed tunables for the PR Gate eval suite.")
model PrGateSuiteInputs {
  @doc("Override the LLM model used by {@ReviewAgent} during the eval run") llm_model?: string;
  @doc("Number of trial runs per PR sample") trials?: int32;
}

@doc("Must-pass gate composing the PR Review Quality scorer against the PR Gate dataset. Runs before every release branch cut.")
@evalSuite(#{
  title: "PR Gate",
  priority: Priority.Must,
  expects: #[
    "{@Evals.PrReview.E001.Score} >= 0.75",
  ],
})
@calls([Evals.PrReview.E001.Score, d001_pr_gate, Components.ReviewAgent.Graph.classify_findings])
op PrGateSuite(inputs: PrGateSuiteInputs): void;
