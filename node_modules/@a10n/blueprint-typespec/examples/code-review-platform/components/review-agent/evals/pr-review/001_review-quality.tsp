import "@a10n/blueprint-typespec";
import "../../../../components/review-agent/main.tsp";
import "../../../../components/review-api-service/main.tsp";
import "../../../../products/review-bot/features/pr-review.tsp";
import "../../../../products/review-bot/features/pr-review-config.tsp";

using State;
using Components.ReviewAgent;
using Components.ReviewApiService;
using Products.ReviewBot.Features.PrReview;

namespace Components.ReviewAgent;

@doc("Measures the overall quality of AI-generated code review output for a {@PullRequest}: actionability of {@ReviewComment.body}, calibration of {@ReviewComment.severity}, specificity of comment location, completeness of file coverage, and internal count consistency of {@ReviewSummary.total_comments}.")
@eval(#{
  title: "PR Review Quality",
})
namespace Evals.PrReview.E001 {

@signal(#{
  title: "Comment body is actionable",
  method: SignalMethod.Probabilistic,
  criteria: "Does {@ReviewComment.body} state a concrete problem AND provide a suggested fix or corrective guidance?",
  examples: #[
    #{
      value: true,
      description: "Comment: 'Line 42: null check missing before getUser() — add `if user == nil { return err }` to avoid a nil-pointer panic when the upstream API returns null for deleted users'",
    },
    #{
      value: false,
      description: "Comment: 'This could be better' — states no specific problem and offers no guidance",
    },
  ],
})
@projects(Products.ReviewBot.Features.PrReview.body_actionable)
op E001_01(): boolean;

@signal(#{
  title: "Severity is correctly calibrated",
  method: SignalMethod.Probabilistic,
  criteria: "Does the assigned {@ReviewComment.severity} match the actual impact of the described issue? Calibration is correct when the assigned level is within one tier of the true level.",
  examples: #[
    #{
      value: true,
      description: "Issue is SQL injection (security vulnerability); assigned {@Severity.critical} — correct calibration",
    },
    #{
      value: false,
      description: "Issue is extra blank line between methods (style preference); assigned {@Severity.critical} — severe over-labelling, calibration is wrong",
    },
  ],
})
@projects(Products.ReviewBot.Features.PrReview.severity_calibrated)
op E001_02(): boolean;

@signal(#{
  title: "Comment location specificity",
  method: SignalMethod.Probabilistic,
  criteria: "Given the {@ReviewComment.file} and {@ReviewComment.line} fields, how precisely is the issue located? Choose `exact` if both fields are present and the line exists in the current diff, `file_only` if only the file is identifiable, or `vague` if neither can be determined.",
  examples: #[
    #{
      value: "exact",
      description: "Comment has {@ReviewComment.file} = 'src/auth/login.ts' and {@ReviewComment.line} = 42, and line 42 is part of the PR diff",
    },
    #{
      value: "file_only",
      description: "Comment has {@ReviewComment.file} = 'src/auth/login.ts' but {@ReviewComment.line} refers to a line that was deleted — line reference is invalid after deletion",
    },
    #{
      value: "vague",
      description: "Comment body says 'somewhere in the auth flow' with no {@ReviewComment.file} or line number — location cannot be determined",
    },
  ],
})
@projects(Products.ReviewBot.Features.PrReview.location_specific)
op E001_03(): "exact" | "file_only" | "vague";

@signal(#{
  title: "Changed files analyzed",
  method: SignalMethod.Probabilistic,
  criteria: "For each file path in the {@PullRequest} diff, does the review output contain at least one {@ReviewComment} anchored to that file, or an explicit 'no issues' note for it?",
  examples: #[
    #{
      value: "{ \"src/auth/login.ts\": true, \"src/db/query.ts\": true, \"tests/auth.test.ts\": true }",
      description: "All 3 changed files have corresponding review output — perfect coverage",
    },
    #{
      value: "{ \"src/auth/login.ts\": true, \"src/db/query.ts\": false, \"tests/auth.test.ts\": true }",
      description: "src/db/query.ts was not analyzed — coverage gap; E001_04_score = 2/3 = 0.67",
    },
  ],
})
@projects(Products.ReviewBot.Features.PrReview.files_analyzed)
op E001_04(): Record<boolean>;

@signal(#{
  title: "Summary comment count matches actual count",
  method: SignalMethod.Deterministic,
  criteria: "Is {@ReviewSummary.total_comments} == len(returned {@ReviewComment} list)?",
  examples: #[
    #{
      value: true,
      description: "{@ReviewSummary.total_comments} = 5 and 5 {@ReviewComment} records were returned — counts match",
    },
    #{
      value: false,
      description: "{@ReviewSummary.total_comments} = 5 but only 3 {@ReviewComment} records were returned — off-by-two discrepancy",
    },
  ],
})
@projects(Products.ReviewBot.Features.PrReview.count_consistent)
op E001_05(): boolean;

@calls([E001_01, E001_02, E001_03, E001_04, E001_05])
@scoring(#{
  formula: """
    E001_04_score = sum(E001_04.values()) / len(E001_04)
    E001_03_score = { exact: 1.0, file_only: 0.5, vague: 0.0 }[E001_03]
    score = (E001_01 × 0.30) + (E001_02 × 0.25) + (E001_03_score × 0.20) + (E001_04_score × 0.15) + (E001_05 × 0.10)
    pass = score >= 0.75
  """,
  examples: #[
    "Perfect review (all signals max): score = 0.30 + 0.25 + 0.20 + 0.15 + 0.10 = 1.00 ✓ pass",
    "Actionable, good severity, exact loc, 2/3 files, count wrong: score = 0.30 + 0.25 + 0.20 + (0.67×0.15) + 0.00 = 0.85 ✓ pass",
    "Not actionable, miscalibrated, file-only, 1/2 files, count ok: score = 0.00 + 0.00 + (0.5×0.20) + (0.5×0.15) + 0.10 = 0.275 ✗ fail",
  ],
  boundaryCases: #[
    "PR has only 1 changed file: E001_04 is a single-entry hashmap { file: 0|1 }. Still valid; E001_04_score is either 0.0 or 1.0 with no partial credit possible.",
    "Comment on deleted line: line reference is invalid after the diff is applied, so {@ReviewComment.line} cannot be verified → E001_03 = file_only (score 0.5), not exact.",
    "Empty diff (zero changed files): E001_04 is an empty hashmap; E001_04_score = 1.0 by convention (vacuously true — nothing to analyze and nothing was missed). E001_01 through E001_03 are evaluated only if at least one {@ReviewComment} was produced; if none, they are scored 0 and the eval is flagged as N/A for those signals.",
    "All comments hit the {@PrReviewConfig.maxComments} cap: run eval against the uncapped internal list captured before truncation; record the cap value as eval metadata for diagnosis.",
  ],
})
@configImpact(PrReviewConfig.maxComments, #{ relationship: "When the limit is reached, later files in the diff may receive fewer comments or none. Lower values shrink E001_04_score because files analyzed last are at risk of being cut off before receiving any comment. Eval should be run against the pre-truncation comment list, not the truncated GitHub post, to isolate agent quality from config limits." })
@configImpact(PrReviewConfig.severityThreshold, #{ relationship: "Comments below the threshold are filtered out before posting. Eval MUST run on the full pre-filtered output from {@ReviewAgent}, not on the subset posted to GitHub, to avoid rewarding over-severe labelling as a workaround for filtering." })
op Score(): float32;

}
