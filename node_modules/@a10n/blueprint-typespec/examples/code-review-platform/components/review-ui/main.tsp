import "@a10n/blueprint-typespec";
import "../review-api-service/main.tsp";
import "../review-agent/main.tsp";
import "../../dependencies/github/main.tsp";
import "../github-service/main.tsp";
import "../review-relational-store/main.tsp";
import "../code-index-sdk/main.tsp";
import "./routes/main.tsp";

using State;
using Components.ReviewApiService;
using Components.ReviewAgent;
using Dependencies.Github;
using Components.ReviewRelationalStore;
using Components.CodeIndexSdk;

@doc("Web UI for monitoring and managing automated code reviews — lists in-flight and completed reviews, surfaces per-file findings with severity badges, exposes real-time status via SSE, and serves as the human decision point for {@Components.ReviewAgent.Tools.post_review_interrupt} responses.")
@component(#{
  type: ComponentType.Ui,
  source: "https://github.com/example/review-bot",
})
@dependsOn([Components.GithubService, Components.ReviewApiService, Components.ReviewRelationalStore, Components.CodeIndexSdk])
@testing(Components.ReviewApiService, #{
  approach: TestingApproach.Real,
  reasoning: "Drive a real ReviewApiService instance in tests so that end-to-end route rendering exercises actual HTTP responses and SSE stream delivery. Mocking the API would mask serialisation mismatches, pagination edge cases in list filtering, and incorrect SSE event handling — all of which are primary UI responsibilities.",
})
@testing(Components.GithubService, #{
  approach: TestingApproach.Mock,
  reasoning: "Replace GitHub webhook delivery and REST calls with deterministic test fixtures. The UI never calls GitHub directly; it only receives data that ReviewApiService already fetched. Mocking prevents live webhook fan-out during CI and gives full control over pull request diff payloads used in detail-view rendering tests.",
})
@testing(Components.ReviewRelationalStore, #{
  approach: TestingApproach.Real,
  reasoning: "Use a real ReviewRelationalStore instance backed by a test database. {@Components.ReviewUi.Routes.ReviewList} list filtering, sort order, and pagination depend on actual database query semantics. Mocking the store would not exercise the real cursor-based pagination or concurrent {@ReviewStatus} transitions that SSE tests need to trigger.",
})
@testing(Components.CodeIndexSdk, #{
  approach: TestingApproach.Mock,
  reasoning: "Replace the CodeIndexSdk with a fake that returns deterministic index entries and search results, keeping settings route tests fast and reproducible without a live vector index.",
})
@testing(BrowserDom, #{
  approach: TestingApproach.Real,
  reasoning: "Run route tests in a headless browser. SSE subscription lifecycle, optimistic status updates, severity badge rendering, and the multi-step {@Components.ReviewUi.Routes.ReviewApprovalOverlay} decision form all require real DOM APIs and event loop semantics that jsdom cannot faithfully replicate.",
})
namespace Components.ReviewUi {}
