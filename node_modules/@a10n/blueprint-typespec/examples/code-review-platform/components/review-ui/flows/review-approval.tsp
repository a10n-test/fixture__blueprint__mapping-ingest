import "@a10n/blueprint-typespec";
import "../routes/main.tsp";

using State;

namespace Components.ReviewUi.Flows.ReviewApproval;

@operation(#{})
@calls([Components.ReviewApiService.Mcp.get_review, Components.ReviewApiService.Mcp.cancel_review, Components.ReviewApiService.Mcp.trigger_review])
@reads([Components.ReviewRelationalStore.StoredReview, Components.ReviewRelationalStore.StoredComment])
@writes([Components.ReviewRelationalStore.StoredReview, Components.ReviewRelationalStore.StoredComment])
@doc("Multi-route operator journey spanning ReviewListRoute → ReviewDetailRoute → ReviewApprovalOverlay. Entry into the approval overlay is triggered by an asynchronous interrupt event rather than a user action, making the state handoff across routes load-bearing.")
op review_approval_flow(): void;
