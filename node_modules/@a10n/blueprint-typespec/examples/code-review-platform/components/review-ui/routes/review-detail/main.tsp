import "@a10n/blueprint-typespec";
import "../../../review-api-service/main.tsp";
import "../../../review-relational-store/main.tsp";

using State;
using Components.ReviewApiService.Mcp;
using Components.ReviewRelationalStore;

@doc("Full detail view for a single review. Surfaces per-file findings, severity distribution, and real-time agent progress. Exposes cancel and the human approval action for interrupt-gated reviews.")
@uiRoute(#{
  path: "/reviews/:review_id",
  designs: #[#{ url: "https://figma.com/file/reviewbot-detail" }],
})
namespace Components.ReviewUi.Routes.ReviewDetail {

  @doc("Mount: load review detail and subscribe to its live progress stream.")
  @calls([get_review])
  @reads([StoredReview, StoredComment])
  op on_mount(review_id: string): UiCommand<ReviewDetailLocalState>;

  @doc("Inbound SSE status update from the review stream — refreshes local review state.")
  @writes([StoredReview])
  op on_stream_delta(event: unknown): UiCommand<ReviewDetailLocalState>;

  @doc("Cancel the in-flight review.")
  @calls([cancel_review])
  @writes([StoredReview])
  op on_cancel(): UiCommand<ReviewDetailLocalState>;

  @doc("Open the approval overlay when an interrupt is pending.")
  @reads([StoredReview, StoredComment])
  op on_open_approval(): UiCommand<void, Push<Components.ReviewUi.Routes.ReviewApprovalOverlay>>;

  @doc("Navigate back to the review list.")
  @reads([StoredReview])
  op on_back(): UiCommand<void, Pop>;

  @doc("Local state model for the review-detail route.")
  model ReviewDetailLocalState {
    review: unknown;
    comments: unknown[];
    streamConnected: boolean;
  }
}
