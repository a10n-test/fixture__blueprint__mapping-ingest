import "@a10n/blueprint-typespec";
import "../../../review-api-service/main.tsp";
import "../../../review-relational-store/main.tsp";
using State;
using Components.ReviewApiService.Mcp;
using Components.ReviewApiService.Http;
using Components.ReviewRelationalStore;

@doc("Configuration surface for review behaviour. Lets operators tune per-repo review policy without code changes.")
@uiRoute(#{
  path: "/settings",
  designs: #[#{ url: "https://figma.com/file/reviewbot-settings" }],
})
namespace Components.ReviewUi.Routes.ReviewSettings {

  @doc("Mount: load current index state and review configuration from the store.")
  @reads([IndexEntry])
  op on_mount(): UiCommand<SettingsLocalState>;

  @doc("Save updated configuration settings and trigger a repository re-index.")
  @calls([ReviewApiServiceHTTP.triggerIndex])
  @writes([IndexEntry])
  op on_save(settings: unknown): UiCommand<SettingsLocalState>;

  @doc("Navigate back to the review list.")
  @reads([IndexEntry])
  op on_back(): UiCommand<void, Pop>;

  @doc("Local state model for the settings route.")
  model SettingsLocalState {
    config: unknown;
    dirty: boolean;
  }
}
