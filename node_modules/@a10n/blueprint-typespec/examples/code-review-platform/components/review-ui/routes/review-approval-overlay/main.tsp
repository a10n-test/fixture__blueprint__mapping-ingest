import "@a10n/blueprint-typespec";
import "../../../review-api-service/main.tsp";
import "../../../review-relational-store/main.tsp";

using State;
using Components.ReviewApiService.Mcp;
using Components.ReviewRelationalStore;

@doc("Human interrupt-response overlay. Presents the verdict the agent is about to post and collects the operator decision — approve, reject, or edit — before execution resumes. Non-addressable: no URL.")
@uiRoute
namespace Components.ReviewUi.Routes.ReviewApprovalOverlay {

  @doc("Mount: load pending interrupt payload for the review.")
  @calls([get_review])
  @reads([StoredReview, StoredComment])
  op on_mount(review_id: string): UiCommand<ApprovalLocalState>;

  @doc("Approve the pending verdict and resume agent execution.")
  @calls([trigger_review])
  @writes([StoredReview])
  op on_approve(): UiCommand<void, Pop>;

  @doc("Reject the pending verdict and abort agent execution for this review.")
  @calls([cancel_review])
  @writes([StoredReview, StoredComment])
  op on_reject(): UiCommand<void, Pop>;

  @doc("Dismiss the overlay and return to the detail view.")
  @reads([StoredReview])
  op on_dismiss(): UiCommand<void, Pop>;

  @doc("Local state model for the approval overlay.")
  model ApprovalLocalState {
    pendingComments: unknown[];
    decision?: string;
  }
}
