import "@a10n/blueprint-typespec";
import "../../../../review-relational-store/main.tsp";

using State;
using Components.ReviewRelationalStore;

@doc("Embedded filter panel inside the review list. Non-addressable: no path. Composed by nesting, not via @calls.")
@uiRoute
namespace Components.ReviewUi.Routes.ReviewList.FilterPanel {

  @doc("Apply the selected status filter to the review list.")
  @reads([StoredReview])
  op on_apply_filter(status?: string): UiCommand<FilterPanelLocalState>;

  @doc("Clear all active filters.")
  @reads([StoredReview])
  op on_clear_filters(): UiCommand<FilterPanelLocalState>;

  @doc("Local state for the filter panel.")
  model FilterPanelLocalState {
    pendingStatus?: string;
  }
}
