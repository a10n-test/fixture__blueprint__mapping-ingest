import "@a10n/blueprint-typespec";
import "../../../review-api-service/main.tsp";
import "../../../review-relational-store/main.tsp";
import "./filter-panel/main.tsp";

using State;
using Components.ReviewApiService.Mcp;
using Components.ReviewRelationalStore;

@doc("Entry point listing all in-flight and completed code reviews. Operators scan review status at a glance, apply {@StoredReviewStatus} filters, and trigger new reviews from this surface.")
@uiRoute(#{
  path: "/reviews",
  designs: #[#{ url: "https://figma.com/file/reviewbot-list" }],
})
namespace Components.ReviewUi.Routes.ReviewList {

  @doc("Mount: load all stored reviews from the store and subscribe to the status stream.")
  @calls([trigger_review, get_review])
  @reads([StoredReview])
  op on_mount(): UiCommand<ReviewListLocalState>;

  @doc("Trigger a new code review for a pull request URL entered by the operator.")
  @calls([trigger_review])
  @writes([StoredReview])
  op on_trigger_review(pr_url: string): UiCommand<ReviewListLocalState>;

  @doc("Navigate to the detail view for the selected review.")
  @reads([StoredReview])
  op on_review_selected(review_id: string): UiCommand<void, Push<Components.ReviewUi.Routes.ReviewDetail>>;

  @doc("Navigate to the settings surface.")
  @reads([StoredReview])
  op on_open_settings(): UiCommand<void, Push<Components.ReviewUi.Routes.ReviewSettings>>;

  @doc("Local state model for the review-list route.")
  model ReviewListLocalState {
    reviews: unknown[];
    filterStatus?: string;
    streamConnected: boolean;
  }

}
