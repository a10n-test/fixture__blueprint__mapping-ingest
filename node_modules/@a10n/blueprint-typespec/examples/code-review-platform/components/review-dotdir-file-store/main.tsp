import "@a10n/blueprint-typespec";

using State;

@doc("File-store component that owns the ReviewBot dotdir configuration files: plugin registry and hook scripts committed alongside the consumer repository.")
@component(#{
  type: ComponentType.Store,
})
@storage(#{ provider: StorageProvider.filesystem, root: ".review-bot" })
namespace Components.ReviewDotdirFileStore {

  @doc("Path model for a named hook script under `.review-bot/hooks/`.")
  model HookScriptPath {
    @doc("Kebab-case hook name, e.g. `pre-review` or `post-comment`") name: string;
  }

  @doc("Body of a shell hook script executed at a named lifecycle point.")
  @mediaTypeHint("text/x-shellscript")
  @storageObject(#{ path: "hooks/{@HookScriptPath.name}.sh" })
  model HookScript {
    @doc("Shell script source content") content: string;
  }

  @doc("Singleton YAML file listing all active review plugins.")
  @mediaTypeHint("application/yaml")
  @storageObject(#{ path: "plugins.yaml" })
  model PluginRegistry {
    @doc("List of npm package names of active plugins") plugins: string[];
  }
}
