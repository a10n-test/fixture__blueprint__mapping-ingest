import "@a10n/blueprint-typespec";
import "@a10n/typespec-dbml";

using State;

@doc("SQLite database schema contract for the ReviewBot system. Owns the table layout for pull request reviews, inline comments, and code-index metadata. No running process — the spec here is the component.")
@component(#{
  type: ComponentType.Store,
})
namespace Components.ReviewRelationalStore {
@doc("Lifecycle status of a stored pull request review")
enum StoredReviewStatus {
  @doc("Review has been requested but not yet started")
  pending: "pending",

  @doc("Review agent is actively processing the pull request")
  running: "running",

  @doc("Review finished successfully and comments have been posted")
  completed: "completed",

  @doc("Review terminated with an unrecoverable error")
  failed: "failed",
}

@doc("Persisted record of a single pull request review session")
@TypeSpec.Dbml.table(#{ name: "stored_review" })
model StoredReview {
  @doc("Unique identifier for this review record")
  id: string;

  @doc("Full URL of the pull request being reviewed, e.g. https://github.com/org/repo/pull/42")
  pr_url: string;

  @doc("Full URL of the repository containing the pull request")
  repo_url: string;

  @doc("Current lifecycle status of the review")
  status: StoredReviewStatus;

  @doc("UTC timestamp when this review record was first created")
  created_at: utcDateTime;

  @doc("UTC timestamp when the review reached a terminal state (completed or failed); null while in progress")
  completed_at?: utcDateTime;
}

@doc("A single review comment anchored to a file and line, as stored before and after posting")
@TypeSpec.Dbml.table(#{ name: "stored_comment" })
model StoredComment {
  @doc("Unique identifier for this comment record")
  id: string;

  @doc("Foreign key referencing the {@StoredReview} this comment belongs to")
  review_id: string;

  @doc("Repository-relative path of the file this comment is anchored to")
  file: string;

  @doc("Line number in the file where this comment is anchored")
  line: int32;

  @doc("Human-readable comment body explaining the finding")
  body: string;

  @doc("Severity classification string for the finding, e.g. critical, major, minor, nitpick")
  severity: string;

  @doc("UTC timestamp when this comment was posted to the pull request; null if not yet posted")
  posted_at?: utcDateTime;
}

@doc("Metadata record tracking the indexing state of a repository at a given ref")
@TypeSpec.Dbml.table(#{ name: "index_entry" })
model IndexEntry {
  @doc("Full URL of the indexed repository")
  repo_url: string;

  @doc("Git ref (branch name, tag, or commit SHA) that was indexed")
  ref: string;

  @doc("Current indexing status string, e.g. queued, indexing, ready, failed")
  status: string;

  @doc("UTC timestamp when indexing completed and the index became queryable; null while in progress")
  indexed_at?: utcDateTime;

  @doc("Number of code chunks stored in the index for this repo at this ref")
  chunk_count: int32;
}
}
