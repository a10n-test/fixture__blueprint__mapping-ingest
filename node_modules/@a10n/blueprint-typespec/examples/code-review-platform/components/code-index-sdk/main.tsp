import "@a10n/blueprint-typespec";
import "../../dependencies/openai/main.tsp";
import "../open-ai-service/main.tsp";
import "../review-relational-store/main.tsp";
import "./operations/main.tsp";

using State;
using Dependencies.Openai;
using Components.ReviewRelationalStore;

@doc("Importable library that developers use to search, retrieve, and index source code for analysis. Provides semantic search over code chunks, raw file retrieval, changed-file enumeration across refs, and background repository indexing — backed by vector embeddings and the {@ReviewRelationalStore} index metadata.")
@component(#{
  type: ComponentType.Sdk,
  source: "https://github.com/example-org/code-index-sdk",
})
@dependsOn([Components.OpenAIService, Components.ReviewRelationalStore])
@testing(Components.OpenAIService, #{
  approach: TestingApproach.Mock,
  reasoning: "Embedding calls are expensive and non-deterministic across API versions. A fake embeddings client returns fixed vectors for known inputs, making search ranking tests fully deterministic and free.",
})
@testing(Components.ReviewRelationalStore, #{
  approach: TestingApproach.Real,
  reasoning: "Index queries require a real SQLite database to verify ranking, pagination, and chunk-count correctness. An in-memory SQLite instance is seeded per test case to keep tests isolated and fast.",
})
namespace Components.CodeIndexSdk {}
