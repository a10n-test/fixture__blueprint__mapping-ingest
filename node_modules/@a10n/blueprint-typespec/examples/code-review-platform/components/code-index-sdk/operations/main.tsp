import "@a10n/blueprint-typespec";

using State;

namespace Components.CodeIndexSdk;

@doc("Change classification for a single file in a diff")
enum ChangeType {
  @doc("File did not exist in the base ref and was created in the head ref")
  added: "added",

  @doc("File existed in both refs and its content changed")
  modified: "modified",

  @doc("File existed in the base ref and was removed in the head ref")
  deleted: "deleted",

  @doc("File was moved to a new path between the two refs")
  renamed: "renamed",
}

@doc("Lifecycle status of a background repository indexing job")
enum IndexStatus {
  @doc("Job has been accepted and is waiting for an indexing worker to pick it up")
  queued: "queued",

  @doc("An indexing worker is currently processing the repository")
  indexing: "indexing",

  @doc("Indexing completed successfully; the repository is queryable")
  ready: "ready",

  @doc("Indexing failed with an unrecoverable error; inspect the job log for details")
  failed: "failed",
}

@doc("A scored code chunk returned by a semantic search query")
model CodeChunk {
  @doc("Repository-relative path of the source file containing this chunk")
  file: string;

  @doc("Line number (1-based, inclusive) where this chunk starts")
  start_line: int32;

  @doc("Line number (1-based, inclusive) where this chunk ends")
  end_line: int32;

  @doc("Raw source text of this chunk")
  content: string;

  @doc("Cosine similarity score in [0, 1] between the query embedding and this chunk's embedding; higher is more relevant")
  score: float32;
}

@doc("Raw content of a file at a specific git ref")
model FileContent {
  @doc("Repository-relative path of the retrieved file")
  path: string;

  @doc("Full raw text content of the file at the requested ref")
  content: string;

  @doc("Git ref (branch name, tag, or commit SHA) at which the file was retrieved")
  ref: string;

  @doc("Size of the file content in bytes")
  size_bytes: int32;
}

@doc("A single file entry from a diff between two git refs")
model ChangedFile {
  @doc("Repository-relative path of the file; for renamed files, this is the destination path")
  path: string;

  @doc("How this file changed between the base and head refs")
  change_type: ChangeType;

  @doc("Number of lines added in this file between the two refs")
  additions: int32;

  @doc("Number of lines deleted from this file between the two refs")
  deletions: int32;
}

@doc("Error when repository has no ready index")
model RepoNotIndexedError {
  code: "REPO_NOT_INDEXED";
  message: string;
}

@doc("Error when query exceeds token limit")
model QueryTooLongError {
  code: "QUERY_TOO_LONG";
  message: string;
}

@doc("Error when file is not found")
model FileNotFoundError {
  code: "FILE_NOT_FOUND";
  message: string;
}

@doc("Error when git ref is not found")
model RefNotFoundError {
  code: "REF_NOT_FOUND";
  message: string;
}

@doc("Error when indexing job is already running")
model AlreadyIndexingError {
  code: "ALREADY_INDEXING";
  message: string;
}

@doc("Error when access is denied to repository")
model AccessDeniedError {
  code: "ACCESS_DENIED";
  message: string;
}

namespace Operations {
  @doc("Search indexed code chunks using a natural-language or code-snippet query. Returns the top matching chunks ranked by semantic similarity score.")
  @operation(#{})
  op search(
    @doc("Natural-language or code-snippet query string to search for")
    query: string,

    @doc("Full URL of the repository to search within; must have been indexed prior to calling")
    repo_url: string,

    @doc("Maximum number of {@CodeChunk} results to return; defaults to 10")
    limit?: int32 = 10,
  ): {
    @doc("Ranked list of matching code chunks, sorted descending by similarity score")
    results: CodeChunk[];
  } | RepoNotIndexedError | QueryTooLongError;

  @doc("Retrieve the full raw content of a file at the specified git ref. Use when analysis requires the complete file rather than a ranked chunk slice.")
  @operation(#{})
  op get_file(
    @doc("Full URL of the repository containing the file")
    repo_url: string,

    @doc("Repository-relative path of the file to retrieve")
    path: string,

    @doc("Git ref (branch name, tag, or commit SHA) to read the file at; defaults to the default branch HEAD when omitted")
    ref?: string,
  ): FileContent | FileNotFoundError | RefNotFoundError;

  @doc("Enumerate all files changed between two git refs in the repository. Suitable for driving per-file analysis passes.")
  @operation(#{})
  op list_changed_files(
    @doc("Full URL of the repository to diff")
    repo_url: string,

    @doc("Base git ref (older); the diff is computed from this ref toward head_ref")
    base_ref: string,

    @doc("Head git ref (newer); the diff is computed toward this ref from base_ref")
    head_ref: string,
  ): {
    @doc("All files that differ between base_ref and head_ref")
    files: ChangedFile[];
  } | RefNotFoundError;

  @doc("Submit a background job to index a repository at the given ref. Returns immediately with a job_id and initial status; poll or subscribe to determine when IndexStatus reaches ready.")
  @operation(#{})
  op index_repo(
    @doc("Full URL of the repository to index")
    repo_url: string,

    @doc("Git ref (branch name, tag, or commit SHA) to index; the index is keyed on repo_url + ref")
    ref: string,
  ): {
    @doc("Opaque identifier for the submitted indexing job; use this to correlate status updates")
    job_id: string;

    @doc("Initial status of the job at the moment it was submitted")
    status: IndexStatus;
  } | AlreadyIndexingError | AccessDeniedError;
}
