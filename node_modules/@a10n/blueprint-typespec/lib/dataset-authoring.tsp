import "../dist/src/index.js";

using TypeSpec.Reflection;
using State;

// ── Storage provider enum ─────────────────────────────────────────────────────

enum StorageProvider {
  filesystem: "filesystem",
  blob: "blob",
  git: "git",
}

// ── Dataset-authoring decorator declarations ──────────────────────────────────

extern dec evalSuite(target: Operation, config: valueof {
  title: string;
  priority: Priority;
  expects: string[];
});

extern dec dataset(target: Operation, config: valueof {
  title: string;
});

extern dec storage(target: Namespace, config: valueof {
  provider: StorageProvider;
  root?: string;
});

extern dec storageGroup(target: Namespace, config: valueof {
  prefix: string;
});

extern dec storageObject(target: Model, config: valueof {
  path: string;
});
