import "../dist/src/index.js";
import "@typespec/json-schema";
import "./dataset-authoring.tsp";

using TypeSpec.Reflection;
using TypeSpec.JsonSchema;

// ── Enums used in decorator parameters ────────────────────────────────────────

namespace State {
  /** Component kind — determines which structural rules apply. */
  enum ComponentType {
    /** Actor that uses tools to perform work. */
    Agent,
    /** HTTP/MCP gateway or background service. */
    Service,
    /** Database schema contract; no running process. */
    Store,
    /** Importable library; no running process. */
    Sdk,
    /** Web application with routes. */
    Ui,
  }

  /** Kind of external dependency. */
  enum DependencyType {
    /** Standard external service, library, or framework. */
    Standard,
    /** External HTTP/REST service. */
    Service,
    /** External SDK or library. */
    Library,
  }

  /** Whether the external dependency integration is actively maintained. */
  enum DependencyStatus {
    /** Integration is live and in use. */
    Active,
    /** Integration is being phased out. */
    Deprecated,
    /** Integration is planned but not yet built. */
    Planned,
    /** Integration is under active evaluation; not yet committed. */
    Evaluation,
  }

  /** Whether the dependency should be real or mocked in tests. */
  enum TestingApproach {
    /** Use a real instance of the dependency in tests. */
    Real,
    /** Replace the dependency with a controllable fake. */
    Mock,
  }

  /** MoSCoW priority for evals and test cases. */
  enum Priority {
    /** Core quality. System unacceptable without it. */
    Must,
    /** Important. Degraded but functional without it. */
    Should,
    /** Nice-to-have. Enhances quality but not essential. */
    Could,
    /** Out of scope for current iteration. */
    Wont,
  }

  /** How a signal value is obtained. */
  enum SignalMethod {
    /** Computed directly from output without judgment. */
    Deterministic,
    /** Requires LLM-as-judge or human annotation. */
    Probabilistic,
  }

  // ── Worker config types ───────────────────────────────────────────────────────

  /** How messages are dispatched across worker instances. */
  enum ConcurrencyMode { Singleton, OnePerKey, Parallel }

  /** Message delivery guarantee. */
  enum DeliveryGuarantee { AtLeastOnce, AtMostOnce, ExactlyOnce }

  /** When the broker considers a message acknowledged. */
  enum AckPolicy { AutoOnReturn, Manual, Transactional }

  /** Back-off strategy for retry delays. */
  enum BackoffStrategy { None, Linear, Exponential }

  /** Retry configuration for a worker. */
  model RetryPolicy {
    max_attempts: int32;
    backoff: BackoffStrategy;
    initial_delay_ms?: int32;
    max_delay_ms?: int32;
  }

  /** Configuration for a @worker namespace. */
  model WorkerConfig {
    concurrency: ConcurrencyMode;
    routing_key?: string;
    delivery?: DeliveryGuarantee;
    max_in_flight?: int32;
    ack: AckPolicy;
    retry?: RetryPolicy;
    dead_letter?: string;
  }

  // ── Graph routing types ───────────────────────────────────────────────────────
  // Imported by every @graph namespace. Command carries the state delta and next node;
  // End signals branch termination.

  /** Routing command returned by @node ops. */
  model Command<TUpdate, TGoTo> {
    update: TUpdate;
    go_to: TGoTo;
  }

  /** Terminal marker — the go_to target that ends a branch. */
  model End {}

  namespace BrowserDom {}

  /** External caller initiating a flow — human user, webhook, or API client. Identifies the entry point of a flow. */
  scalar Actor extends string;

  // ── UI route return types ─────────────────��───────────────────────────────────
  //
  // Action ops inside @uiRoute namespaces return UiCommand<LocalState?, Nav?>.
  // Both type parameters are optional:
  //   - omit LocalState (or use void) when the action does not update local state
  //   - omit Nav when the action only updates local state without navigating
  //   - Pop/Reload/Push are the navigation verbs; no Stay needed (omitting Nav = stay)

  /** Pop the current route off the navigation stack and return to the previous one. */
  model Pop {}

  /** Reload the current route from scratch (re-run on_mount). */
  model Reload {}

  /** Push a new route onto the navigation stack. T is the target @uiRoute namespace. */
  model Push<T> {
    route: T;
  }

  /** Replace the current route with another without adding a history entry. */
  model Replace<T> {
    route: T;
  }

  /** Return type for action ops inside @uiRoute namespaces.
   * LocalState: the updated local-state patch (omit or use void when unchanged).
   * Nav: the navigation verb — Pop, Reload, Push<T>, or Replace<T>.
   *      Omit when the action only updates local state and navigation stays put. */
  model UiCommand<LocalState = void, Nav = void> {
    state?: LocalState;
    nav?: Nav;
  }
}

// ── Decorator declarations ────────────────────────────────────────────────────
//
// extern dec must be at top level (outside any namespace) so TypeSpec resolves
// JS implementations from dist/src/index.js via the package tspMain.
// Return types are omitted — TypeSpec decorators have no return type syntax.

using State;

extern dec component(target: Namespace, config: valueof {
  type: ComponentType;
  source?: string;
  /** Target language for generated type files — used by the type emitter to pick the right language backend. */
  language?: string;
});

extern dec dependsOn(target: Namespace | Operation, deps: Namespace[]);

extern dec testing(target: Namespace, dep: Namespace, config: valueof {
  approach: TestingApproach;
  reasoning: string;
});

extern dec tool(target: Operation, config?: valueof {
  sequential?: boolean;
});

extern dec operation(target: Operation, config: valueof {});

/** @interrupt — no-arg marker on a dedicated op called by @tool or @node via @calls. */
extern dec interrupt(target: Operation);

/** @graph — marks a sub-namespace inside @component Agent as a graph. */
extern dec graph(target: Namespace);

/** @node — marks an op inside a @graph namespace as a routing node. is_entrypoint: exactly one per graph; is_join: receives multiple incoming branches. */
extern dec node(target: Operation, config?: valueof {
  is_entrypoint?: boolean;
  is_join?: boolean;
});

/** @predict — marks an op inside a @graph namespace as a model boundary. */
extern dec predict(target: Operation);

extern dec feature(target: Namespace, config?: valueof {
  name?: string;
});

extern dec product(target: Namespace, config?: valueof {
  name?: string;
});

extern dec uiRoute(target: Namespace, config?: valueof { path?: string; designs?: { url: string }[]; });

extern dec assumption(target: Namespace, entry: valueof {
  id: string;
  assumption: string;
  source: string;
});

extern dec dependency(target: Namespace, config: valueof {
  title: string;
  type: DependencyType;
  status: DependencyStatus;
  sources: {
    url: string;
    description: string;
  }[];
  why?: string[];
  how?: string[];
  gotchas?: string[];
});

extern dec featureConfig(target: Model);

extern dec entity(target: Model);

extern dec invariant(target: Operation, config: valueof {
  predicate: string;
  why: string;
});

extern dec projects(target: Model | ModelProperty | Operation, ...refs: unknown[]);

extern dec eval(target: Namespace, config: valueof {
  title: string;
});

extern dec signal(target: Operation, config: valueof {
  title: string;
  method: SignalMethod;
  criteria: string;
  examples: { value: unknown; description: string }[];
});

extern dec scoring(target: Operation, config: valueof {
  formula: string;
  examples: string[];
  boundaryCases: string[];
});

extern dec configImpact(target: Operation, param: unknown, config: valueof {
  relationship: string;
});

extern dec flow(target: Operation);

extern dec calls(target: Operation, ops: Operation[]);
extern dec reads(target: Operation, models: Model[]);
extern dec writes(target: Operation, models: Model[]);

/** @publishes(variant) — declares that this operation emits the given event variant.
 * May be applied multiple times; each application adds one entry. */
extern dec publishes(target: Operation, variant: UnionVariant);

/** @subscribes — marker; the op's input parameter type declares which events it reacts to.
 * Must be inside a @worker namespace. */
extern dec subscribes(target: Operation);

/** @worker — marks a namespace as a worker; must be nested inside a @component namespace. */
extern dec worker(target: Namespace, config?: valueof WorkerConfig);
// TODO: migrate to a more robust TypeSpec DB schema decorator once available
// See: https://github.com/microsoft/typespec/issues/10334
