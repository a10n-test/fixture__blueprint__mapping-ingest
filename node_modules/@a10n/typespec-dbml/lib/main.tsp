import "../dist/src/index.js";

using TypeSpec.Reflection;

namespace TypeSpec.Dbml;

/** Groups models into a named database schema (controls which models are emitted as tables). */
extern dec schema(target: Namespace | Model, name?: valueof string);

/** Configures table-level DBML options (name override, table-level Note). */
extern dec table(target: Model, config: valueof { name?: string; note?: string });

/** Marks a property as a primary key. For composite PKs, apply to multiple properties. */
extern dec primaryKey(target: ModelProperty);

/** Marks a property as having a UNIQUE constraint. */
extern dec unique(target: ModelProperty);

/** Marks a property as a foreign key referencing the PK of the given model. */
extern dec references(target: ModelProperty, ref: Model);

/**
 * Declares an index.
 * On a ModelProperty: declares a single-column secondary index.
 * On a Model: declares a composite index (requires `columns`).
 * Apply multiple times for multiple indexes.
 */
extern dec index(target: ModelProperty | Model, config?: valueof { columns?: string[]; name?: string; unique?: boolean; note?: string });

/**
 * Generic extensible per-column metadata (follows TypeSpec DB proposal).
 * Common keys: "default" (SQL default value; wrap SQL expressions in backticks, e.g. "`now()`").
 */
extern dec columnOption(target: ModelProperty, key: valueof string, value: valueof string);

/** Emits a `// comment` line immediately before this column in the DBML output. */
extern dec columnComment(target: ModelProperty, comment: valueof string);

/** Marks a TypeSpec enum as a DBML Enum block to be emitted. */
extern dec dbmlEnum(target: Enum);

/** Integer that auto-increments (maps to DBML `increment`). */
scalar autoIncrement extends int64;

/** Timestamp with timezone — maps to DBML `timestamptz`. */
scalar timestamptz extends string;
